---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import Footer from '../components/Footer.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  description?: string;
  breadcrumb?: Crumb[];
  activeCategory?: string;
}
const {
  title,
  description = 'Personal reference library of data structures and algorithms — formal pseudocode, complexity analysis, and ready-to-adapt templates.',
  breadcrumb = [],
  activeCategory = '',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    <meta name="generator" content={Astro.generator} />
    <meta name="base-url" content={base} />
    <ClientRouter />
  </head>
  <body>
    <Header breadcrumb={breadcrumb} />
    <div class="layout">
      <Sidebar activeCategory={activeCategory} />
      <div class="main">
        <slot />
        <Footer />
      </div>
    </div>
    <SearchOverlay />
  </body>
</html>
